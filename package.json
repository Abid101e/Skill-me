{
  "name": "skillme",
  "version": "0.1.0",
  "description": "The missing package manager for Claude Code plugins",
  "bin": {
    "skillme": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plugins",
    "skills",
    "ai",
    "cli"
  ],
  "author": "Md. Abid Hasan",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "tsup": {
    "entry": ["src/cli.ts"],
    "format": ["cjs"],
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}
